# Copy this file to .env.local and fill in real values.
# Never commit .env.local

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# App Store / TestFlight link the "Get in the app" buttons point to.
# During TestFlight: https://testflight.apple.com/join/XXXXXXXX
# After launch:     https://apps.apple.com/app/idXXXXXXXXX
NEXT_PUBLIC_APP_STORE_URL=https://testflight.apple.com/join/XXXXXXXX

# Contact form recipient (used as a mailto: fallback on the contact page)
NEXT_PUBLIC_CONTACT_EMAIL=hello@jaegerlongevity.com
